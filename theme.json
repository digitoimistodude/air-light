{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "border": {
      "color": false,
      "radius": false,
      "style": false,
      "width": false
    },
    "dimensions": {
      "defaultAspectRatios": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": []
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1440px",
      "allowCustomContentAndWideSize": false
    },
    "spacing": {
      "units": ["px", "rem", "%", "vw"],
      "customSpacingSize": false,
      "defaultSpacingSizes": false,
      "padding": ["top", "bottom"],
      "margin": ["top", "bottom"],
      "blockGap": false,
      "spacingSizes": [
        {
          "slug": "s",
          "size": "clamp(0.375rem, 0.8571rem + 0.7143vw, 0.75rem)",
          "name": "S"
        },
        {
          "slug": "m",
          "size": "clamp(0.75rem, 1.2143rem + 1.4286vw, 1.5rem)",
          "name": "M"
        },
        {
          "slug": "l",
          "size": "clamp(1.5rem, 1.7857rem + 3.5714vw, 3rem)",
          "name": "L"
        }
      ]
    },
    "color": {
      "custom": false,
      "customGradient": false,
      "defaultGradients": false,
      "gradients": [],
      "defaultPalette": false,
      "palette": [
        {
          "slug": "black",
          "color": "#000000",
          "name": "Black"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "light",
          "color": "#f5f5f5",
          "name": "Light"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "fluid": true,
      "fontStyle": false,
      "fontWeight": false,
      "lineHeight": false,
      "letterSpacing": false,
      "textDecoration": false,
      "textTransform": false,
      "dropCap": false,
      "fontFamilies": [
        {
          "slug": "main",
          "fontFamily": "'Mona Sans', -apple-system, 'BlinkMacSystemFont', 'Segoe UI', 'Helvetica', 'Arial', sans-serif",
          "name": "Mona Sans",
          "fontFace": [
            {
              "fontFamily": "Mona Sans",
              "fontWeight": "1 999",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": ["file:./assets/fonts/monasansvf.woff2"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "12", "size": "12px", "name": "12", "fluid": false },
        { "slug": "13", "size": "13px", "name": "13", "fluid": false },
        { "slug": "14", "size": "14px", "name": "14", "fluid": false },
        { "slug": "15", "size": "15px", "name": "15", "fluid": false },
        { "slug": "16", "size": "16px", "name": "16", "fluid": false },
        { "slug": "17", "size": "17px", "name": "17", "fluid": false },
        { "slug": "18", "size": "18px", "name": "18", "fluid": false },
        { "slug": "20", "size": "20px", "name": "20", "fluid": false },
        { "slug": "22", "size": "22px", "name": "22", "fluid": false },
        {
          "slug": "body-s",
          "size": "clamp(0.75rem, 0.647rem + 0.2747vw, 0.875rem)",
          "name": "Body S"
        },
        {
          "slug": "body-m",
          "size": "clamp(0.875rem, 0.772rem + 0.2747vw, 1rem)",
          "name": "Body M"
        },
        {
          "slug": "body-l",
          "size": "clamp(1rem, 0.897rem + 0.2747vw, 1.125rem)",
          "name": "Body L"
        },
        {
          "slug": "body-xl",
          "size": "clamp(1.125rem, 1.022rem + 0.2747vw, 1.25rem)",
          "name": "Body XL"
        },
        {
          "slug": "heading-xxs",
          "size": "clamp(1rem, 0.897rem + 0.2747vw, 1.125rem)",
          "name": "Heading XXS"
        },
        {
          "slug": "heading-xs",
          "size": "clamp(1.125rem, 1.022rem + 0.2747vw, 1.25rem)",
          "name": "Heading XS"
        },
        {
          "slug": "heading-s",
          "size": "clamp(1.25rem, 1.044rem + 0.5495vw, 1.5rem)",
          "name": "Heading S"
        },
        {
          "slug": "heading-m",
          "size": "clamp(1.5rem, 1.0879rem + 1.0989vw, 2rem)",
          "name": "Heading M"
        },
        {
          "slug": "heading-l",
          "size": "clamp(1.75rem, 1.1319rem + 1.6484vw, 2.5rem)",
          "name": "Heading L"
        },
        {
          "slug": "heading-xl",
          "size": "clamp(2rem, 1.1758rem + 2.1978vw, 3rem)",
          "name": "Heading XL"
        },
        {
          "slug": "heading-xxl",
          "size": "clamp(2rem, 0.3516rem + 4.3956vw, 4rem)",
          "name": "Heading XXL"
        }
      ]
    },
    "custom": {
      "gridBase": "1440px",
      "spacing": {
        "gridGap": "3rem",
        "containerPaddingInline": "1.25rem",
        "containerPaddingInlineLarge": "4rem",
        "containerPaddingBlock": "4rem",
        "siteHeaderPaddingBlock": "1.25rem",
        "contentPaddingBlock": "5rem",
        "textMarginBlock": "2.5rem",
        "wpBlockImageMarginBlock": "2.5rem",
        "paragraphsMarginBlock": "1.6875rem"
      },
      "color": {
        "accent": "var(--wp--preset--color--black)",
        "heading": "var(--wp--preset--color--black)",
        "main": "var(--wp--preset--color--black)",
        "paragraph": "var(--wp--preset--color--black)",
        "linkText": "var(--wp--preset--color--black)",
        "linkTextHover": "var(--wp--preset--color--black)"
      },
      "typography": {
        "weightRegular": "400",
        "weightMedium": "500",
        "weightSemibold": "600",
        "weightBold": "700",
        "weightParagraph": "400",
        "weightHeading": "700",
        "paragraphLineHeight": "1.7",
        "headingLineHeight": "1.5",
        "headingCoreLineHeight": "1.23",
        "captionsSize": "15px",
        "navToggleLabelSize": "15px"
      },
      "fontWeight": {
        "regular": 400,
        "medium": 500,
        "semi-bold": 600,
        "bold": 700
      },
      "lineHeight": {
        "none": 1,
        "body": 1.7,
        "heading": 1.5
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|white",
      "text": "var:preset|color|black"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|main",
      "fontSize": "var:preset|font-size|body-m",
      "lineHeight": "var:custom|line-height|body",
      "fontWeight": "var:custom|font-weight|regular"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|s",
      "padding": {
        "top": "0",
        "right": "var:preset|spacing|s",
        "bottom": "0",
        "left": "var:preset|spacing|s"
      }
    },
    "elements": {
      "link": {
        "color": {
          "text": "var:preset|color|black"
        }
      },
      "button": {
        "border": {
          "radius": "0",
          "width": "1px",
          "style": "solid",
          "color": "var:preset|color|black"
        },
        "color": {
          "background": "var:preset|color|black",
          "text": "var:preset|color|white"
        },
        "spacing": {
          "padding": {
            "top": "12px",
            "right": "20px",
            "bottom": "12px",
            "left": "20px"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|body-m",
          "fontWeight": "var:custom|font-weight|medium"
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|black",
            "text": "var:preset|color|white"
          }
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|main",
          "fontWeight": "var:custom|font-weight|bold",
          "lineHeight": "var:custom|line-height|heading"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var:preset|font-size|heading-xl",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|heading-l"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|heading-m"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var:preset|font-size|heading-s"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var:preset|font-size|heading-xs"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var:preset|font-size|heading-xxs"
        }
      }
    }
  }
}
